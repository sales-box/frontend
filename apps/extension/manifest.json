{
  "manifest_version": 3,
  "name": "Inbox Sales Copilot",
  "version": "1.0.0",
  "description": "AI-powered sales reply assistant for Gmail",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://mail.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["src/content.tsx"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/assets/fonts/Fraunces-upright-latin.woff2",
        "src/assets/fonts/Fraunces-italic-latin.woff2",
        "src/assets/fonts/Inter-latin.woff2",
        "src/assets/fonts/JetBrainsMono-latin.woff2"
      ],
      "matches": ["https://mail.google.com/*"]
    }
  ]
}
