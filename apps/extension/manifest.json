{
  "manifest_version": 3,
  "key": "",
  "name": "Inbox Sales Copilot",
  "version": "1.0.0",
  "description": "AI-powered sales reply assistant for Gmail",
  "permissions": ["activeTab", "scripting", "storage", "identity"],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://salesbox.dev/*",
    "https://*.salesbox.dev/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*"
  ],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "icons": {
    "16": "favicon-96x96.png",
    "48": "favicon-96x96.png",
    "128": "web-app-manifest-192x192.png"
  },
  "action": {
    "default_icon": {
      "16": "favicon-96x96.png",
      "48": "favicon-96x96.png",
      "128": "web-app-manifest-192x192.png"
    }
  },
  "oauth2": {
    "client_id": "676907443704-jms8lovn48lsl0tqjlhrjff12kfe1ojv.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/gmail.readonly"]
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["src/content.tsx"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/assets/fonts/Baloo2-latin.woff2",
        "src/assets/fonts/PlusJakartaSans-latin.woff2",
        "src/assets/fonts/JetBrainsMono-latin.woff2",
        "src/assets/mascot-auth.png",
        "src/assets/mascot-locked.png",
        "src/assets/mascot-sleepy.png",
        "src/assets/mascot-icon-silhouette.svg"
      ],
      "matches": ["https://mail.google.com/*"]
    }
  ]
}
